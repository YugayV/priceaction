// Group: Core Settings
var string G_CORE = "Core Settings"
source        = input.source(hl2, 'Source', group = G_CORE, tooltip = 'The price data used to calculate the SNR anchor channel.')
length        = input.int(200, 'SNR Period', 2, group = G_CORE, tooltip = 'The number of bars back used to calculate the SNR anchor channel.')

// Group: SNR Channel Settings
