// ＣＡＬＣＵＬＡＴＩＯＮＳ――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――{

buildLinearSnr() =>
    array<float> preds = array.new_float(0)
    if barstate.islast
        float reg_now = ta.linreg(source, length, 0)
        float reg_prev = ta.linreg(source, length, 1)
        float reg_slope_step = reg_now - reg_prev
        float oldest_val = reg_now - reg_slope_step * (length - 1)
        for i = 0 to length - 1
            float pred_val = oldest_val + reg_slope_step * i
            array.push(preds, pred_val)
    preds

// Calculate baseline SNR anchor
array<float> predictions = buildLinearSnr()

// Determine 1 Standard Deviation 
stdev_val = ta.stdev(source, length)

// Scale calculation step sizes so 3 SD boundary matches max outer channel constraint
dev = (stdev_val * 3) / num_bins

// }
// ＰＬＯＴ ――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――{

type ArchPoint
    float feat1
    float feat2
    float score

var polyline[] active_lines = array.new<polyline>()
var table info_dash = na
