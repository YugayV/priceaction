num_bins      = input.int(20, 'Outer Band Width', 5, group = G_GRID, tooltip = 'Controls how far the outer SNR bands sit from the anchor line.')
showLiveSnr   = input.bool(true, "Show Live SNR Levels", group = G_GRID, tooltip = "Plots the live SNR basis and outer levels across the chart for clearer reading.")

// Group: Trend Colors & POC Settings
