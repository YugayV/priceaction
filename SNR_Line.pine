dashRows = dashModeInput == "Minimal" ? 10 : 18 + (showAiPanel ? 1 : 0)

// Helper function to map text selections to native line style properties
getLineStyle(styleText) =>
    switch styleText
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// Helper function to map text selections to native table text sizes
getDashSize(sizeText) =>
    switch sizeText
        "Auto"   => size.auto
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        => size.normal

string baseStyle = getLineStyle(baseStyle_)
string gridStyle = getLineStyle(gridStyle_)
string pocStyle  = getLineStyle(pocStyle_)
string dashSize  = getDashSize(dashSize_)
string TZ_KST    = "Asia/Seoul"

colAsia      = color.new(color.rgb(51, 153, 255), 80)
colLondon    = color.new(color.rgb(0, 163, 108), 80)
colNewYork   = color.new(color.rgb(210, 68, 90), 80)
colSilver    = color.new(color.rgb(180, 140, 255), 75)
colBullBos   = color.rgb(48, 176, 112)
colBearBos   = color.rgb(201, 77, 83)
colBullChoch = color.rgb(38, 208, 178)
colBearChoch = color.rgb(232, 111, 51)
colBullSweep = color.rgb(0, 200, 140)
colBearSweep = color.rgb(255, 120, 70)
colBullFvg = color.rgb(66, 196, 150)
colBearFvg = color.rgb(214, 96, 96)
colLongEntry = color.rgb(0, 214, 143)
colShortEntry = color.rgb(255, 87, 87)
colSbEntry = color.rgb(190, 120, 255)
